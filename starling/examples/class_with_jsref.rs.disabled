        //         assert_eq!(result_str15, "HI, ASYNC-WORLD!");
        //         println!("  chainResult = '{}' (expected 'HI, ASYNC-WORLD!')", result_str15);

        println!("All tests passed!");
    }
}

#[test]
fn class_with_jsref_example() {
    main()
}
